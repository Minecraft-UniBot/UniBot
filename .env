# NoneBot 框架配置
# 配置 Nonebot 监听的端口。
PORT=8000
# 配置 Nonebot 监听的 IP / 主机名。
# 如果需要公网连接，请把此项改为 0.0.0.0。
HOST="127.0.0.1"
# 超级用户（拥有管理权限的用户的 QQ 号）。
# 请注意，QQ 号外须加上双引号（英文状态下的半角符号），两个号码间用逗号隔开。
SUPERUSERS=["1234567890"]
# 配置 Nonebot 命令起始字符。
COMMAND_SEP=[" "]
COMMAND_START=["."]
# 日志输出等级，默认填写 INFO 即可。
LOG_LEVEL="INFO"

# 适配器配置
# OneBot 平台（如 Lagrange.OneBot，GoCqhttp，LLOnebot 等）的 AccessToken。
# 如若没有设置，删除即可。
ONEBOT_ACCESS_TOKEN=""

# Minecraft 适配器配置
# 建议使用反向 WebSocket Client
# 使用 nonebot-adapter-minecraft 连接 Minecraft 服务器（鹊桥 / QueQiao 插件）。
# 格式为：{"服务器名称": ["ws://地址:端口/路径"]}
# 如果连接多个服务器，可配置多个条目。
# MINECRAFT_WS_URLS={"server1": ["ws://127.0.0.1:8080/mc"]}
# WebSocket 连接令牌（可选），如服务器端设置了访问令牌，需在此填写一致。
# MINECRAFT_ACCESS_TOKEN=""

# 自定义配置已迁移至 config.toml
